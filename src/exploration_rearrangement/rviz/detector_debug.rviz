      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: -0.409797728061676
      Target Frame: camera_color_optical_frame
      Value: Orbit (rviz_default_plugins)
      Yaw: 4.618197917938232
